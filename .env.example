# ============================================================
# Tkicks — Variables de entorno
# Copia este archivo como .env.local y completá los valores
# ============================================================

# ── Supabase (Públicas — Client-side) ──────────────────────
# URL de tu proyecto Supabase (Settings → API → URL)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon/public key (Settings → API → anon key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Supabase (Privada — Server-side only) ──────────────────
# Service role key — NUNCA exponer al cliente
# (Settings → API → service_role key)
SUPABASE_SERVICE_ROLE=eyJ...

# ── Node ───────────────────────────────────────────────────
NODE_ENV=development

# ── Playwright (E2E testing — opcional) ────────────────────
# BASE_URL=http://localhost:3000

# ============================================================
# SETUP ADICIONAL REQUERIDO EN SUPABASE:
#
# 1. Ejecutar las migraciones SQL:
#    - supabase/schema.sql (esquema base)
#    - supabase/migration-checkout-flow.sql (funciones de stock)
#    - supabase/setup-storage.sql (buckets de storage)
#
# 2. Crear buckets de Storage:
#    - "product-images" (público)
#    - "payment-proofs" (privado, acceso con service role)
#
# 3. Configurar RLS según supabase/rls-security-update.sql
# ============================================================
